{
  "name": "@interop/edv-conformance-suite",
  "description": "A conformance test suite for Encrypted Data Vault (EDV) servers, runnable against any implementation over HTTPS.",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "edv-conformance": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "conformance": "vitest run --config vitest.conformance.config.ts",
    "fix": "eslint --fix src test configs && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"configs/**/*.ts\" \"*.md\"",
    "lint": "eslint src test configs",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run lint && pnpm run test:node",
    "test:node": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@interop/data-integrity-core": "^7.0.0",
    "@interop/did-method-key": "^7.3.1",
    "@interop/ed25519-signature": "^7.1.1",
    "@interop/ed25519-verification-key": "^8.0.0",
    "@interop/edv-client": "^17.0.1",
    "@interop/ezcap": "^7.2.0",
    "@interop/http-signature-zcap-invoke": "^6.2.2",
    "@interop/minimal-cipher": "^7.2.0",
    "@interop/security-document-loader": "^9.3.0",
    "@interop/x25519-key-agreement-key": "^4.0.2",
    "@interop/zcap": "^11.0.2",
    "@scure/base": "^2.2.0",
    "undici": "^7.0.0",
    "vitest": "^4.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "edv",
    "encrypted-data-vault",
    "conformance",
    "test-suite",
    "zcap"
  ],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0"
  },
  "author": {
    "name": "Interop Alliance",
    "url": "https://github.com/interop-alliance/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/edv-conformance-suite.git"
  },
  "homepage": "https://github.com/interop-alliance/edv-conformance-suite",
  "bugs": "https://github.com/interop-alliance/edv-conformance-suite/issues"
}
